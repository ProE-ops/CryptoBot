# ============================================
# CONTENT BOT - Environment Configuration
# ============================================
# Copy file này thành .env và điền thông tin của bạn
# cp .env.example .env

# === TELEGRAM BOT (BẮT BUỘC) ===
# Tạo bot tại https://t.me/BotFather → /newbot
TELEGRAM_BOT_TOKEN=8869770322:AAGkcLyZY6zG1Eq11TTEHRwovH9D8la6J6I
# ID channel đăng bài (VD: -1001234567890)
TELEGRAM_TARGET_CHANNEL=-1001234567890
# Telegram User ID của admin (lấy từ @userinfobot)
ADMIN_USER_IDS=1557712827

# === TELEGRAM CRAWLER - GramJS (TÙY CHỌN) ===
# Để crawl tin từ các channel Telegram
# Lấy API ID/Hash từ https://my.telegram.org/apps
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# Chạy: pnpm auth:telegram để tạo session string
TELEGRAM_SESSION=

# === TWITTER CRAWL (TÙY CHỌN) ===
# Bearer token để đọc tweets
# Lấy từ https://developer.x.com → Keys and Tokens
TWITTER_BEARER_TOKEN=

# === TWITTER PUBLISH (TÙY CHỌN) ===
TWITTER_EN_API_KEY=
TWITTER_EN_API_SECRET=
TWITTER_EN_ACCESS_TOKEN=
TWITTER_EN_ACCESS_SECRET=

# === DEEPSEEK AI (BẮT BUỘC) ===
# Lấy từ https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# === CHART-IMG (KHUYẾN NGHỊ - cho chart đẹp như TradingView) ===
# Free 100 req/tháng, Basic $9/tháng. Sign up tại https://chart-img.com
# Không có key → bot dùng QuickChart fallback (xấu hơn)
CHARTIMG_API_KEY=

# === CRYPTOPANIC (KHUYẾN NGHỊ) ===
# News aggregator + sentiment. Free 1000 req/day
# Lấy tại https://cryptopanic.com/developers/api/
CRYPTOPANIC_API_KEY=

# === COINGLASS (TÙY CHỌN) ===
# Liquidation data. Free tier.
# Lấy tại https://www.coinglass.com/api
COINGLASS_API_KEY=

# === INTERVALS (giây) ===
CRAWL_INTERVAL=60
PROCESS_INTERVAL=15
PUBLISH_INTERVAL=5
TWITTER_PUBLISH_INTERVAL=20

# === TÙY CHỌN ===
AUTO_PUBLISH=true
# Set true nếu tài khoản X có Premium (cho phép post >280 chars)
TWITTER_PREMIUM=false
LOG_LEVEL=info
